#!/bin/bash
# AgentForge Task Dispatcher
TASK_ID="$1"
AGENT="$2"
DESC="$3"
PRIORITY="${4:-medium}"

echo "[Dispatcher] Dispatching task $TASK_ID to agent $AGENT (priority=$PRIORITY)"

# Make sure logs directory exists
mkdir -p /home/eveselove/agentforge/logs

# Run grok_worker.py to execute the task pipeline asynchronously
python3 /home/eveselove/agentforge/core/grok_worker.py --gateway http://127.0.0.1:9090 --repo /home/eveselove/agentforge --gateway-task "$TASK_ID" > /home/eveselove/agentforge/logs/grok_${TASK_ID}.log 2>&1 &

echo "[Dispatcher] Spawned background worker for task $TASK_ID"
