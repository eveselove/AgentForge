[Unit]
Description=Autonomous Product Matching Engine (port 8500)
After=network.target planly-gateway.service reranker.service llm-judge.service
Wants=reranker.service llm-judge.service

[Service]
Environment=AGENTFORGE_PURE_RUST_FLYWHEEL=1
Environment=FLYWHEEL_PROVENANCE=rust-agentforge-runner
# task-5af0e350 pure default
Type=simple
User=agx
WorkingDirectory=/home/agx/planlytasksko
ExecStart=/usr/bin/python3 /home/agx/planlytasksko/scripts/autonomous_matcher.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
