# AgentForge Rust Flywheel env snippet (updated for PURE RUST DEFAULT, task-5af0e350)
# Source early in grok_worker.sh / jules_worker.sh / dispatcher.sh / runners / services:
#   source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/rust_flywheel.env" 2>/dev/null || true
# or legacy: source /path/to/bin/rust_flywheel.env
#
# PURE RUST FLYWHEEL is now the HARD DEFAULT (marker + env).
# To rollback: DISABLE_RUST_FLYWHEEL=1 or touch .disable_pure_rust_flywheel
# Provenance: always sets FLYWHEEL_PROVENANCE=rust-agentforge-runner for logs/health.
_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" 2>/dev/null && pwd || echo "$HOME/agentforge/bin")"
AGENTFORGE_ROOT="${AGENTFORGE_ROOT:-$(cd "$_SCRIPT_DIR/.." 2>/dev/null && pwd || echo "/home/eveselove/agentforge")}"
_DISABLE_FILE="$AGENTFORGE_ROOT/.disable_rust_flywheel"
_DISABLE_PURE_FILE="$AGENTFORGE_ROOT/.disable_pure_rust_flywheel"
if [[ "${DISABLE_RUST_FLYWHEEL:-0}" = "1" ]] || [[ -f "$_DISABLE_FILE" ]] || [[ -f "$_DISABLE_PURE_FILE" ]]; then
    export AGENTFORGE_RUST_FLYWHEEL=0
    export AGENTFORGE_USE_RUST=0
    export AGENTFORGE_PURE_RUST_FLYWHEEL=0
else
    export AGENTFORGE_RUST_FLYWHEEL=1
    export AGENTFORGE_USE_RUST=1
    # PURE is hard default when not disabled (marker may be used as signal too)
    export AGENTFORGE_PURE_RUST_FLYWHEEL=1
    # Prefers release binary everywhere (prod default)
    if [[ -x "$AGENTFORGE_ROOT/rust/target/release/agentforge-runner" ]]; then
      _DEF_RUNNER="$AGENTFORGE_ROOT/rust/target/release/agentforge-runner"
    else
      _DEF_RUNNER="$AGENTFORGE_ROOT/rust/target/debug/agentforge-runner"
    fi
    export AGENTFORGE_RUST_RUNNER="${AGENTFORGE_RUST_RUNNER:-$_DEF_RUNNER}"
    # Rate-limit preserved (every N post_process calls)
    export AGENTFORGE_RUST_FLYWHEEL_EVERY_N="${AGENTFORGE_RUST_FLYWHEEL_EVERY_N:-5}"
    # Provenance for all health, manifests, logs (enforced for 14d soak)
    export FLYWHEEL_PROVENANCE="rust-agentforge-runner"
    export AGENTFORGE_FLYWHEEL_PROVENANCE="rust-agentforge-runner"
fi
# Also export ROOT for consumers
export AGENTFORGE_ROOT="$AGENTFORGE_ROOT"
# Note: callers should also export AGENTFORGE_PURE_RUST_FLYWHEEL=1 explicitly in services for belt+suspenders.
