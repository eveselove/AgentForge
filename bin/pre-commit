#!/bin/bash
# AgentForge Pre-Commit Hook (v2)
# Enforces basic quality (secrets/size/fmt/clippy/lint).
# Traceability lives in the commit-msg hook (bin/commit-msg).

set -e

echo "🔍 AgentForge pre-commit checks..."

# 1. Block obvious secrets
if git diff --cached --name-only -z | xargs -0 grep -l -iE '(AKIA|ghp_|xai-|AQ\.Ab8RN)' 2>/dev/null; then
    echo "❌ Possible secret or key found in staged files!"
    exit 1
fi

# 2. Block very large files
git diff --cached --name-only | while read -r file; do
    if [ -f "$file" ]; then
        size=$(stat -c%s "$file" 2>/dev/null || echo 0)
        if [ "$size" -gt 800000 ]; then
            echo "❌ File too large for commit: $file ($size bytes)"
            exit 1
        fi
    fi
done

# 3. Rust checks
if git diff --cached --name-only | grep -q '\.rs$'; then
    echo "→ Rust: cargo fmt check..."
    cargo fmt -- --check || { echo "❌ Run 'cargo fmt' first"; exit 1; }

    echo "→ Rust: cargo clippy..."
    cargo clippy --workspace -- -D warnings || exit 1
fi

# 4. Python checks
if git diff --cached --name-only | grep -qE '\.py$'; then
    echo "→ Python: ruff check..."
    ruff check . --fix || true
    echo "→ Python: black check..."
    black --check . || { echo "❌ Run 'black .' first"; exit 1; }
fi

# 5b. Shell scripts (shellcheck) - advisory for now, will become blocking
if git diff --cached --name-only | grep -qE '\.sh$'; then
    if command -v shellcheck >/dev/null 2>&1; then
        echo "→ Shell: shellcheck on staged .sh..."
        git diff --cached --name-only | grep '\.sh$' | xargs -r shellcheck || echo "⚠️  shellcheck warnings (non-blocking for now)"
    fi
fi

# Traceability (Task ID / Jules session) is enforced by the commit-msg hook
# (bin/commit-msg -> bin/validate-commit-msg "$1"), which runs AFTER the commit
# message is finalized. pre-commit runs too early (the message is not written
# yet) so it cannot read it reliably -- do NOT re-add a traceability check here.

echo "✅ Pre-commit checks passed"
