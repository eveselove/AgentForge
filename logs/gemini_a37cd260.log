**Пример задачи: Code Review Rust (Tokio/Async)**

Предположим, у вас есть следующий асинхронный обработчик в `planly_gateway`, и вы хотите убедиться, что он эффективен и идиоматичен:

```rust
// src/handlers.rs
use tokio::sync::{Mutex, Arc};
use std::collections::HashMap;
use std::time::Duration;

#[derive(Debug, Clone)]
struct AppState {
    counter: Arc<Mutex<u64>>,
    config: Arc<HashMap<String, String>>,
}

async fn handle_request(state: Arc<AppState>, request_id: String, payload: Vec<u8>) -> Result<Vec<u8>, String> {
    // 1. Увеличиваем счетчик
    let mut counter_guard = state.counter.lock().await;
    *counter_guard += 1;
    println!("Request ID: {}, Counter: {}", request_id, *counter_guard);

    // 2. Читаем конфигурацию
    let max_payload_size_str = state.config.get("max_payload_size").cloned().unwrap_or_else(|| "1024".to_string());
    let max_payload_size: usize = max_payload_size_str.parse().unwrap_or(1024);

    // 3. Обрабатываем полезную нагрузку
    if payload.len() > max_payload_size {
        return Err(format!("Payload too large: {} > {}", payload.len(), max_payload_size));
    }

    // Имитация асинхронной работы
    tokio::time::sleep(Duration::from_millis(50)).await;

    // 4. Возвращаем модифицированную полезную нагрузку
    let mut response_payload = payload;
    response_payload.extend_from_slice(request_id.as_bytes());
    Ok(response_payload)
}
```

