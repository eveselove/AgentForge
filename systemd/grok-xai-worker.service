[Unit]
Description=AgentForge Grok XAI Cloud Worker
After=network.target

[Service]
Type=simple
User=agx
WorkingDirectory=/home/eveselove/agentforge
EnvironmentFile=/home/eveselove/agentforge/.env.xai
ExecStart=/bin/bash /home/eveselove/agentforge/grok_xai_worker.sh
Restart=always
RestartSec=10
StandardOutput=append:/home/eveselove/agentforge/logs/grok_xai_worker.service.log
StandardError=append:/home/eveselove/agentforge/logs/grok_xai_worker.service.log

# Ограничения для безопасности
MemoryMax=2G
CPUQuota=80%

[Install]
WantedBy=multi-user.target
