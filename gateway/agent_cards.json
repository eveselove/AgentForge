{
  "agents": [
    {
      "id": "antigravity",
      "name": "Antigravity IDE + Worker",
      "description": "Архитектор, оркестратор, code review, анализ. Полный доступ к инструментам. Автономный воркер на Erbox.",
      "capabilities": ["file_edit", "terminal", "ssh", "browser", "subagents", "mcp", "autonomous"],
      "models": ["gemini-2.5-pro", "gemini-2.5-flash", "claude-opus-4.6", "claude-sonnet-4.6", "grok-3"],
      "max_parallel": 10,
      "strengths": ["architecture", "complex_logic", "code_review", "analysis", "orchestration", "decomposition"],
      "location": "erbox_eveselove + windows_pc_via_ssh",
      "status_endpoint": "/tasks/for/antigravity",
      "invoke": "Antigravity IDE chat"
    },
    {
      "id": "grok",
      "name": "Grok Build",
      "description": "Быстрый мультиагентный исполнитель. Rust, Python, серверные задачи.",
      "capabilities": ["file_edit", "terminal", "git", "multi_agent"],
      "models": ["grok-3"],
      "max_parallel": 20,
      "strengths": ["speed", "rust", "debugging", "fixes", "multi_file"],
      "location": "jetson_agx",
      "version": "0.1.219",
      "invoke": "grok --always-approve -p \"task\"",
      "invoke_alias": "at grok \"task\"",
      "flags": {
        "headless": "--print",
        "auto_approve": "--always-approve",
        "self_check": "--check",
        "best_of_n": "--best-of-n N"
      }
    }
  ],
  "routing_rules": [
    {"condition": "complex OR tags: architecture/analysis/algorithm/review", "agent": "antigravity"},
    {"condition": "default (simple, rust, fixes, routine, test/docs)", "agent": "grok"}
  ],
  "infrastructure": {
    "task_queue": "http://146.120.89.199:9090",
    "jetson": "agx@146.120.89.199",
    "project": "/home/eveselove/agentforge",
    "github": "eveselove/AgentForge"
  }
}
