[Unit]
Description=AgentForge Task Queue API
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=agx
Group=agx
WorkingDirectory=/home/agx/agentforge
Environment=PATH=/home/agx/.local/bin:/home/agx/.cargo/bin:/home/agx/.grok/bin:/usr/local/bin:/usr/bin:/bin
Environment=PROTOC=/home/agx/.local/bin/protoc
ExecStart=/usr/bin/python3 -m uvicorn task_queue:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
StandardOutput=append:/home/agx/agentforge/logs/server.log
StandardError=append:/home/agx/agentforge/logs/server.log

# Автоперезапуск при падении
StartLimitIntervalSec=300
StartLimitBurst=10

[Install]
WantedBy=multi-user.target

Environment=AGENTFORGE_PURE_RUST_FLYWHEEL=1
Environment=AGENTFORGE_FLYWHEEL_ENGINE=rust
Environment=AGENTFORGE_FLYWHEEL_PROVENANCE=rust-agentforge-runner
