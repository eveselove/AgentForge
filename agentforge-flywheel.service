[Unit]
Description=AgentForge Continuous Rust Flywheel Autonomy Closer (meta-loop on top of after-task hooks)
Documentation=https://github.com/agentforge (see CONTINUOUS_FLYWHEEL.md, ANTIGRAVITY_DEFAULT.md)
After=agentforge-api.service agentforge-worker.service
# 2026-06: Rust Flywheel now DEFAULT for Antigravity. This timer drives the continuous promote-and-ab closer
# on top of the automatic per-task flywheel firehose. Disable via DISABLE_RUST_FLYWHEEL=1 in the env block below.
#
# !!! PHASE 3 FINAL DEPRECATION SWEEP + RUNNER UX POLISH !!!
# Python orchestration (run_continuous_flywheel.sh + .py) heavily marked for removal.
# Migrate to (COMPLETE surface): ExecStart=/home/eveselove/agentforge/rust/target/release/agentforge-runner continuous --top-n 2 --json [--shadow]
#   (or via wrapper that detects pure + calls direct runner continuous; supports AGENTFORGE_RUST_FLYWHEEL_SHADOW)
# Guarded by is_pure_rust_flywheel() + make_pure_rust_flywheel_default.sh patches.
# Non-breaking during transition. Shadow for dual-run fidelity validation on farm.

[Service]
Type=oneshot
User=agx
Group=agx
WorkingDirectory=/home/eveselove/agentforge
# Full reuse of existing ENABLE + Rust env (non-breaking)
# 2026-06 DEFAULT: These positive lines are now the normal state for Antigravity.
# To disable the entire flywheel for this unit: add Environment=DISABLE_RUST_FLYWHEEL=1 and comment the three AGENTFORGE_RUST_* lines.
Environment=ENABLE_RUST_FLYWHEEL=1
Environment=AGENTFORGE_RUST_FLYWHEEL=1
Environment=AGENTFORGE_USE_RUST=1
Environment=AGENTFORGE_RUST_RUNNER=/home/eveselove/agentforge/rust/target/release/agentforge-runner
Environment=PYTHONPATH=/home/eveselove
# Safe default for timer: dry-run can be overridden by ExecStart override or remove comment
# ExecStart=/home/eveselove/agentforge/bin/run_continuous_flywheel.sh --no-dry-run --top-n 2
ExecStart=/home/eveselove/agentforge/bin/run_continuous_flywheel.sh --top-n 2
StandardOutput=append:/home/eveselove/agentforge/logs/continuous_flywheel.log
StandardError=append:/home/eveselove/agentforge/logs/continuous_flywheel.log
# Reliability
TimeoutStartSec=300
KillMode=process

[Install]
WantedBy=default.target

Environment=AGENTFORGE_PURE_RUST_FLYWHEEL=1
Environment=AGENTFORGE_FLYWHEEL_ENGINE=rust
Environment=AGENTFORGE_FLYWHEEL_PROVENANCE=rust-agentforge-runner
