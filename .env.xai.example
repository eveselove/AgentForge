# Пример файла с переменными окружения для Grok XAI воркеров
# Скопируй в .env.xai и заполни

XAI_API_KEY="xai-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# === Умная маршрутизация ===
# Минимальная сложность задач, которые будет брать облачный воркер
# complex | high | medium
XAI_MIN_COMPLEXITY=complex

# Принудительно использовать multi-agent модель на всех задачах
XAI_FORCE_MULTI_AGENT=0
