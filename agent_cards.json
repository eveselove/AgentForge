{
  "agents": [
    {
      "id": "antigravity",
      "name": "Antigravity IDE + Worker",
      "description": "Архитектор, оркестратор, code review, анализ. Полный доступ к инструментам. Автономный воркер на Jetson.",
      "capabilities": [
        "file_edit",
        "terminal",
        "ssh",
        "browser",
        "subagents",
        "mcp",
        "autonomous"
      ],
      "models": [
        "gemini-2.5-pro",
        "gemini-2.5-flash",
        "claude-opus-4.6",
        "claude-sonnet-4.6",
        "grok-3"
      ],
      "max_parallel": 3,
      "strengths": [
        "architecture",
        "complex_logic",
        "code_review",
        "analysis",
        "orchestration",
        "decomposition"
      ],
      "location": "jetson_eveselove + windows_pc",
      "worker": "antigravity_worker.py",
      "status_endpoint": "/tasks/for/antigravity",
      "invoke": "Antigravity IDE chat / autonomous worker"
    },
    {
      "id": "grok",
      "name": "Grok Build",
      "description": "Быстрый мультиагентный исполнитель. Rust, Python, серверные задачи.",
      "capabilities": [
        "file_edit",
        "terminal",
        "git",
        "multi_agent"
      ],
      "models": [
        "grok-3"
      ],
      "max_parallel": 5,
      "strengths": [
        "speed",
        "rust",
        "debugging",
        "fixes",
        "multi_file"
      ],
      "location": "jetson_eveselove",
      "worker": "grok_worker_remote.sh",
      "invoke": "grok --always-approve -p \"task\"",
      "flags": {
        "headless": "--print",
        "auto_approve": "--always-approve",
        "self_check": "--check",
        "best_of_n": "--best-of-n N"
      }
    },
    {
      "id": "jules",
      "name": "Jules",
      "description": "Асинхронный фоновый агент. Создаёт PR в GitHub.",
      "capabilities": [
        "git",
        "github_pr",
        "file_edit",
        "tests"
      ],
      "models": [
        "gemini-2.5-pro"
      ],
      "max_parallel": 1,
      "strengths": [
        "tests",
        "documentation",
        "refactoring",
        "async_tasks"
      ],
      "location": "jetson_eveselove",
      "invoke": "jules remote new --repo <repo> --session \"task\""
    }
  ]
}